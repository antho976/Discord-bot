  app.post('/api/pets/pending/approve', requireAuth, requireTier('admin'), (req, res) => {
    try {
      const { id } = req.body;
      if (!id) return res.json({ success: false, error: 'Missing pending pet id' });
      const petsData = loadJSON(PETS_PATH, { pets: [], catalog: [], pendingPets: [] });
