    "AllWorlds_CrossCutting": [
      {
        "extractor": "tasks.highestTierReached",
        "key": "TaskZZ1",
        "desc": "Highest task tier completed across all categories",
        "method": "Math.max(...TaskZZ1)"
      },
      {
        "extractor": "tasks.totalTiersCompleted",
        "key": "TaskZZ1",
        "desc": "Sum of all task tiers reached",
        "method": "TaskZZ1.reduce(sum)"
      },
      {
        "extractor": "bosses.totalKills",
        "key": "BossInfo",
        "desc": "Total boss kills across all world bosses",
        "method": "BossInfo.reduce((sum,b) => sum + (b[0]||0), 0)"
      },
      {
        "extractor": "steamAchievements.unlocked",
        "key": "SteamAchieve",
        "desc": "Number of Steam achievements not locked (-1=locked)",
