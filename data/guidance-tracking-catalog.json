      },
      {
        "extractor": "account.ageInDays",
        "key": "accountCreateTime (outer)",
        "desc": "Account age in days since creation",
        "method": "(Date.now() - save.accountCreateTime) / 86400000"
      }
    ],

    "PerCharacter_RequiresLoop": [
      {
        "extractor": "chars.maxCombatLevel",
        "key": "Lv0_{i}[0]",
        "desc": "Highest combat level across all characters",
        "perChar": true,
        "method": "Math.max(...chars.map(i => Lv0_{i}[0]))"
      },
      {
        "extractor": "chars.totalSkillLevels",
        "key": "Lv0_{i}",
        "desc": "Sum of all skill levels across all characters",
        "perChar": true,
        "method": "sum all Lv0_{i}[1..19] for all i"
      },
      {
        "extractor": "chars.masterClassCount",
        "key": "CharacterClass_{i}",
        "desc": "Number of characters in a tier-4 master class",
        "perChar": true,
        "method": "count CharacterClass_{i} in [4,5,14,16,29,40] for all i"
      },
      {
        "extractor": "chars.eliteClassCount",
        "key": "CharacterClass_{i}",
        "desc": "Number of characters in elite (tier-3) or master (tier-4) class",
        "perChar": true,
        "method": "count CharacterClass_{i} >= elite tier"
      },
      {
        "extractor": "chars.postOfficeTotalBoxLevels",
        "key": "POu_{i}",
        "desc": "Sum of all PO box upgrade levels across all characters",
        "perChar": true,
        "method": "sum POu_{i}.reduce(sum) for all i"
      },
      {
        "extractor": "chars.questsCompleted",
        "key": "QuestComplete_{i}",
        "desc": "Total quests completed across all characters",
        "perChar": true,
        "method": "sum Object.keys(QuestComplete_{i}).length for all i"
      },
      {
        "extractor": "chars.highestWorldReached",
        "key": "AFKtarget_{i}",
        "desc": "Highest world number any character is farming in (from AFKtarget 'w7b4' format)",
        "perChar": true,
        "method": "Math.max(...chars.map(i => parseInt(AFKtarget_{i}[1]) || 0))"
      },
      {
        "extractor": "chars.statueOfferingTotal",
        "key": "StatueLevels_{i}",
        "desc": "Sum of all statue levels across all characters (vs account gilding)",
        "perChar": true,
        "method": "sum StatueLevels_{i}[statue][0] for all statues, all chars"
      },
      {
        "extractor": "chars.trapsPlaced",
        "key": "PldTraps_{i}",
        "desc": "Total traps placed across all characters",
        "perChar": true,
        "method": "sum PldTraps_{i}.length for all i (non-empty entries)"
      }
    ]
  }
}
